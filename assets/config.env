# Configuración local de la app (se bundlea como asset — sin secretos acá).
#
# API_BASE_URL: dónde vive el gateway de Mecavoltia.
#   - Vacío  → default por plataforma: Android emulador http://10.0.2.2,
#              resto http://localhost
#   - Teléfono físico → la IP de tu PC en el WiFi, ej: http://192.168.0.104
#   - Producción → https://mecavoltia.com (cuando exista el dominio)
API_BASE_URL=https://mecavoltia.com
